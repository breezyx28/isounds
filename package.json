{
  "name": "isounds-v2",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "serve": "bun run server/index.ts",
    "dev:full": "concurrently -n vite,bun -c blue,green \"bun run dev\" \"bun --watch server/index.ts\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "smoke:zoalcast": "bun run ./scripts/smoke-zoalcast.ts",
    "icons:pwa": "bun run ./scripts/generate-pwa-icons.ts",
    "vapid:keys": "bun run ./scripts/generate-vapid-keys.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-three/fiber": "^9.6.1",
    "@reduxjs/toolkit": "^2.8.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.16.0",
    "gsap": "^3.15.0",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.1.0",
    "iconsax-react": "^0.0.8",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^15.5.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.6.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "yup": "^1.7.1"
