# SQLite + SEO require the Bun server (not Vite-only):
#   bun run dev:full   — Vite :3000 + API :8888
#   bun run build && bun run serve — production
VITE_API_BASE_URL=https://api.zoalcast.com/api
VITE_PORTAL_ID=6
VITE_ZAIN_DSP=https://dsplp.sd.zain.com/af-lp/?p=8991632598
SITE_URL=http://localhost:5173
PORT=8888
DB_PATH=./data/isounds.db
# Web Push (run: bun run vapid:keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@isounds.sd
VITE_VAPID_PUBLIC_KEY=
# Episode poller interval ms (default 1800000 = 30 min)
POLL_INTERVAL_MS=1800000
ENABLE_EPISODE_POLLER=true
